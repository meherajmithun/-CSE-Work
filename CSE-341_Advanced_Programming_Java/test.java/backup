import java.util.*;
import java.io.*;
import java.util.ArrayList;

class cropManagement{
    String cropName,season,weather,sunLight;
    int water, price;//in liter
    cropManagement(){}

    cropManagement(String cropName,String season, String weather, String sunLight, int water,int p){
        this.cropName = cropName;
        this.season = season;
        this.weather = weather;
        this.sunLight = sunLight;
        this.water = water;
        this.price = p;
    }

    public String toString(){
        return (cropName+" "+season+" "+weather+" "+sunLight+" "+water+" "+price+"\n");
    }
    public String toStringPrint() {
        return "Crop Name : " + cropName + "\n" +
            "Season : " + season + "\n" +
            "Weather : " + weather + "\n" +
            "Sunlight : " + sunLight + "\n" +
            "Water : " + water + "\n" + 
            "Price : " + price + "\n";
    }
}

public class Main{
    public static void main(String[] args) throws Exception{

        File f = new File("info.txt");
        FileWriter fw = new FileWriter(f,true);
        // ArrayList<cropManagement> data = new ArrayList<>();
        Scanner sc = new Scanner(System.in);

        for(int i=0; i<2; i++){
            System.out.print("CropName : ");  String name = sc.next();
            System.out.print("Season : ");  String season = sc.next();
            System.out.print("Weather : ");  String weather = sc.next();
            System.out.print("SunLight : ");  String sunLight = sc.next();
            System.out.print("Water (Ltr per day) : ");  int water = sc.nextInt();
            System.out.print("Price (Per KG) : ");  int price = sc.nextInt();

            cropManagement c = new cropManagement(name, season, weather, sunLight, water,price);
            fw.write(c.toString());
        }
        fw.close();
    }
}
